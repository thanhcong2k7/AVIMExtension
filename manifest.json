{
  "manifest_version": 3,
  "name": "AVIM Vietnamese Input",
  "version": "1.1",
  "description": "Vietnamese Input Method based on AVIM with EN/VI toggle and Ctrl+Shift shortcut.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches":["<all_urls>"],
      "js": ["avim.js", "content.js"],
      "all_frames": true
    }
  ]
}
